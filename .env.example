# Database
# DATABASE_URL  — Supabase Transaction Pooler (port 6543). Used at runtime by Vercel serverless functions.
# DIRECT_URL    — Supabase Direct Connection (port 5432). Used ONLY by prisma migrate / prisma db push.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# PIN Management
PIN_SALT_ROUNDS=10
PIN_LENGTH=4

# Public Access
PUBLIC_TOKEN_LENGTH=64
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Server
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_PUBLIC_API_URL=http://localhost:3000/api/v1/public
NEXT_PUBLIC_FRONTEND_SIMULADOR_URL=https://tuenergia.axpoiberia.es
FRONTEND_SIMULADOR_URL=https://tuenergia.axpoiberia.es

# Logging
LOG_LEVEL=info

# CORS (comma-separated; include Vercel QA URL in production)
CORS_ORIGIN=http://localhost:3001

# Swagger / API Docs protection (Basic Auth)
# Protects only internal docs endpoints:
# - /api/v1/internal/docs
# - /api/v1/internal/openapi
SWAGGER_BASIC_AUTH_USER=swagger
SWAGGER_BASIC_AUTH_PASS=

# Feature Flags (for Phase 2+)
FEATURE_OCR_ENABLED=false
FEATURE_PDF_EXPORT_ENABLED=false
FEATURE_ANALYTICS_ENABLED=true
