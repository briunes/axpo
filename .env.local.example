# Local Development Database (Docker)
# Use this for local development to avoid touching the preview database
DATABASE_URL=postgresql://axpo:axpo_dev_password@localhost:5432/axpo_simulator
DIRECT_URL=postgresql://axpo:axpo_dev_password@localhost:5432/axpo_simulator

# Authentication
JWT_SECRET=local-dev-jwt-secret-change-me
JWT_EXPIRES_IN=24h

# PIN Management
PIN_SALT_ROUNDS=10
PIN_LENGTH=4

# Public Access
PUBLIC_TOKEN_LENGTH=64
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Server
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_PUBLIC_API_URL=http://localhost:3000/api/v1/public
NEXT_PUBLIC_FRONTEND_SIMULADOR_URL=http://localhost:3000
FRONTEND_SIMULADOR_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Swagger / API Docs protection (Basic Auth)
SWAGGER_BASIC_AUTH_USER=swagger
SWAGGER_BASIC_AUTH_PASS=admin

# Feature Flags
FEATURE_OCR_ENABLED=false
FEATURE_PDF_EXPORT_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
