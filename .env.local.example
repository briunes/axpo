# Local Development Database (Docker)
# Use this for local development to avoid touching the preview database
DB_CONNECTION_MODE=direct
DATABASE_URL=postgresql://axpo:axpo_dev_password@localhost:5432/axpo_simulator
DIRECT_URL=postgresql://axpo:axpo_dev_password@localhost:5432/axpo_simulator

# API mode requires an sb_secret_ key or legacy service_role JWT, never sb_publishable_.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_DB_SCHEMA=public
SUPABASE_CONNECTION_TEST_RPC=axpo_test_api_connection

# Optional legacy credential for local Blob uploads outside Vercel OIDC.
BLOB_READ_WRITE_TOKEN=

# Authentication
JWT_SECRET=local-dev-jwt-secret-change-me
SECURITY_DATA_KEY=local-dev-security-data-key-change-me
JWT_EXPIRES_IN=24h

# PIN Management
PIN_SALT_ROUNDS=10
PIN_LENGTH=4

# Public Access
PUBLIC_TOKEN_LENGTH=64
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Server
NODE_ENV=development
APP_ENV=local
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_PUBLIC_API_URL=http://localhost:3000/api/v1/public
NEXT_PUBLIC_FRONTEND_SIMULADOR_URL=http://localhost:3001
FRONTEND_SIMULADOR_URL=http://localhost:3001

# Logging
LOG_LEVEL=debug

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Swagger / API Docs protection (Basic Auth)
SWAGGER_BASIC_AUTH_USER=swagger
SWAGGER_BASIC_AUTH_PASS=admin

# ─── Sentry Error Tracking ────────────────────────────────────────────────────
# Sign up at https://sentry.io → New Project → Next.js to get these values.
# All three are OPTIONAL for local dev — errors are always saved to the DB.
# NEXT_PUBLIC_SENTRY_DSN = the DSN shown on your Sentry project page
# SENTRY_ORG             = your Sentry organisation slug (e.g. "signed-axpo")
# SENTRY_PROJECT         = your Sentry project slug (e.g. "javascript-nextjs")
# SENTRY_AUTH_TOKEN      = only needed to upload source maps (Settings → Auth Tokens)
NEXT_PUBLIC_SENTRY_DSN=https://a515453df8bc25f40b2a1444b3135e37@o4511472518627328.ingest.de.sentry.io/4511472520659024
SENTRY_ORG=signed-axpo
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
# ──────────────────────────────────────────────────────────────────────────────

# Feature Flags
FEATURE_OCR_ENABLED=false
FEATURE_PDF_EXPORT_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
