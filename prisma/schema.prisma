generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agency {
  id              String         @id @default(cuid())
  name            String
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  street          String?
  city            String?
  postalCode      String?
  province        String?
  country         String?
  deletedAt       DateTime?
  isDeleted       Boolean        @default(false)
  createdByUserId String?
  updatedByUserId String?
  createdByUser   User?          @relation("AgencyCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser   User?          @relation("AgencyUpdatedBy", fields: [updatedByUserId], references: [id])
  agencyTariffs   AgencyTariff[]
  baseValueSets   BaseValueSet[]
  clients         Client[]
  simulations     Simulation[]
  users           User[]

  @@map("agencies")
}

model AgencyTariff {
  id         String   @id @default(cuid())
  agencyId   String
  tariffType String
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  agency     Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, tariffType])
  @@map("agency_tariffs")
}

model Client {
  id              String       @id @default(cuid())
  agencyId        String
  name            String
  isActive        Boolean      @default(true)
  isDeleted       Boolean      @default(false)
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  cif             String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  otherDetails    String?
  createdByUserId String?
  updatedByUserId String?
  agency          Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdByUser   User?        @relation("ClientCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser   User?        @relation("ClientUpdatedBy", fields: [updatedByUserId], references: [id])
  simulations     Simulation[]

  @@map("clients")
}

model User {
  id                          String              @id @default(cuid())
  agencyId                    String
  role                        UserRole            @default(COMMERCIAL)
  fullName                    String
  email                       String              @unique
  pinHash                     String
  pinRotatedAt                DateTime            @default(now())
  isActive                    Boolean             @default(true)
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  passwordHash                String?
  mobilePhone                 String?
  commercialPhone             String?
  commercialEmail             String?
  otherDetails                String?
  pinCurrent                  String?
  createdByUserId             String?
  updatedByUserId             String?
  setupToken                  String?             @unique
  setupTokenExpiresAt         DateTime?
  passwordResetToken          String?             @unique
  passwordResetTokenExpiresAt DateTime?
  deletedAt                   DateTime?
  isDeleted                   Boolean             @default(false)
  createdAgencies             Agency[]            @relation("AgencyCreatedBy")
  updatedAgencies             Agency[]            @relation("AgencyUpdatedBy")
  auditLogs                   AuditLog[]
  baseValueSets               BaseValueSet[]
  createdClients              Client[]            @relation("ClientCreatedBy")
  updatedClients              Client[]            @relation("ClientUpdatedBy")
  triggeredEmailLogs          EmailLog[]
  simulationVersions          SimulationVersion[]
  simulations                 Simulation[]
  preferences                 UserPreferences?
  agency                      Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdByUser               User?               @relation("UserCreatedBy", fields: [createdByUserId], references: [id])
  createdUsers                User[]              @relation("UserCreatedBy")
  updatedByUser               User?               @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id])
  updatedUsers                User[]              @relation("UserUpdatedBy")

  @@map("users")
}

model UserPreferences {
  id           String   @id @default(cuid())
  userId       String   @unique
  dateFormat   String?
  timeFormat   String?
  timezone     String?
  numberFormat String?
  itemsPerPage Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Simulation {
  id                  String              @id @default(cuid())
  agencyId            String
  ownerUserId         String
  status              SimulationStatus    @default(DRAFT)
  expiresAt           DateTime?
  publicToken         String?             @unique
  pinHashSnapshot     String?
  isDeleted           Boolean             @default(false)
  deletedAt           DateTime?
  sharedAt            DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  clientId            String?
  pinSnapshot         String?
  invoiceFilePath     String?
  invoiceFileData     Bytes?
  invoiceFileMimeType String?
  invoiceFileName     String?
  invoiceFileSize     Int?
  accessAttempts      AccessAttempt[]
  versions            SimulationVersion[]
  agency              Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client              Client?             @relation(fields: [clientId], references: [id])
  ownerUser           User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@map("simulations")
}

model SimulationVersion {
  id             String        @id @default(cuid())
  simulationId   String
  payloadJson    Json
  baseValueSetId String?
  createdBy      String
  createdAt      DateTime      @default(now())
  baseValueSet   BaseValueSet? @relation(fields: [baseValueSetId], references: [id])
  createdByUser  User          @relation(fields: [createdBy], references: [id])
  simulation     Simulation    @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@map("simulation_versions")
}

model BaseValueSet {
  id                 String              @id @default(cuid())
  scopeType          BaseValueScope      @default(GLOBAL)
  agencyId           String?
  name               String
  sourceWorkbookRef  String?
  sourceScope        String?
  version            Int                 @default(1)
  isActive           Boolean             @default(true)
  isDeleted          Boolean             @default(false)
  deletedAt          DateTime?
  createdBy          String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isProduction       Boolean             @default(false)
  items              BaseValueItem[]
  agency             Agency?             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdByUser      User                @relation(fields: [createdBy], references: [id])
  simulationVersions SimulationVersion[]

  @@map("base_value_sets")
}

model BaseValueItem {
  id             String       @id @default(cuid())
  baseValueSetId String
  key            String
  valueNumeric   Decimal?
  valueText      String?
  unit           String?
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  baseValueSet   BaseValueSet @relation(fields: [baseValueSetId], references: [id], onDelete: Cascade)

  @@unique([baseValueSetId, key])
  @@map("base_value_items")
}

model AccessAttempt {
  id            String     @id @default(cuid())
  simulationId  String
  tokenFragment String?
  ipHashOrMask  String?
  success       Boolean
  reason        String?
  createdAt     DateTime   @default(now())
  simulation    Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@map("access_attempts")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  eventType    String
  targetType   String
  targetId     String
  metadataJson Json?
  createdAt    DateTime @default(now())
  actor        User?    @relation(fields: [actorUserId], references: [id])

  @@map("audit_logs")
}

model SystemConfig {
  id                              String   @id @default(cuid())
  simulationExpirationDays        Int      @default(30)
  simulationShareText             String   @default("Your simulation is ready. Access it with PIN: {PIN}")
  enablePixelTracking             Boolean  @default(true)
  requirePinForAccess             Boolean  @default(true)
  pinLength                       Int      @default(4)
  autoCreateClientOnSim           Boolean  @default(false)
  enableAnalyticsModule           Boolean  @default(true)
  enableAuditLogsModule           Boolean  @default(true)
  defaultDashboardView            String   @default("COMMERCIAL")
  enableRealtimeReports           Boolean  @default(false)
  updatedAt                       DateTime @updatedAt
  createdAt                       DateTime @default(now())
  smtpFromEmail                   String?
  smtpFromName                    String?  @default("Axpo Simulator")
  smtpHost                        String?
  smtpPassword                    String?
  smtpPort                        Int?     @default(587)
  smtpSecure                      Boolean  @default(false)
  smtpUser                        String?
  userCreationEmailTemplateId     String?
  electricityTaxRate              Decimal  @default(0.051127)
  ivaRate                         Decimal  @default(0.21)
  defaultDateFormat               String   @default("DD/MM/YYYY")
  defaultItemsPerPage             Int      @default(10)
  defaultNumberFormat             String   @default("eu")
  defaultTimeFormat               String   @default("24h")
  defaultTimezone                 String   @default("Europe/Madrid")
  llmApiKey                       String?
  llmBaseUrl                      String?
  llmEnabled                      Boolean  @default(false)
  llmMaxTokens                    Int?     @default(2000)
  llmModelName                    String?  @default("llama3.2")
  llmProvider                     String?  @default("ollama")
  llmTemperature                  Decimal? @default(0.1)
  setupTokenValidityHours         Int      @default(72)
  passwordResetEmailTemplateId    String?
  passwordResetTokenValidityHours Int      @default(24)
  defaultPdfTemplateElectricityId String?
  defaultPdfTemplateGasId         String?
  cronExpirationEnabled           Boolean  @default(true)
  cronExpirationSchedule          String   @default("0 2 * * *")
  cronExpirationTimezone          String   @default("UTC")
  hydrocarbonTaxRate              Decimal  @default(0.00234)

  @@map("system_config")
}

model PdfTemplate {
  id               String    @id @default(cuid())
  name             String
  description      String
  type             String
  active           Boolean   @default(true)
  htmlContent      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  editableSections Json?
  deletedAt        DateTime?
  isDeleted        Boolean   @default(false)
  commodity        String?

  @@map("pdf_templates")
}

model EmailTemplate {
  id               String    @id @default(cuid())
  name             String
  description      String
  type             String
  active           Boolean   @default(true)
  subject          String
  htmlContent      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  editableSections Json?
  deletedAt        DateTime?
  isDeleted        Boolean   @default(false)

  @@map("email_templates")
}

model RolePermission {
  id            String   @id @default(cuid())
  role          UserRole
  permissionKey String
  allowed       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([role, permissionKey])
  @@map("role_permissions")
}

model TemplateVariable {
  id          String    @id @default(cuid())
  key         String    @unique
  label       String
  description String?
  category    String
  example     String?
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  @@map("template_variables")
}

model EmailLog {
  id                  String   @id @default(cuid())
  sentAt              DateTime @default(now())
  recipientEmail      String
  templateId          String?
  templateName        String?
  subject             String
  htmlBody            String
  triggeredBy         String?
  triggeredByUserId   String?
  variables           Json?
  status              String   @default("sent")
  errorMessage        String?
  errorStack          String?
  relatedUserId       String?
  relatedSimulationId String?
  // SMTP delivery details
  smtpHost            String?
  smtpPort            Int?
  fromEmail           String?
  fromName            String?
  messageId           String?
  smtpResponse        String?
  durationMs          Int?
  hasAttachments      Boolean  @default(false)
  attachmentsCount    Int      @default(0)
  triggeredByUser     User?    @relation(fields: [triggeredByUserId], references: [id])

  @@index([sentAt])
  @@index([recipientEmail])
  @@index([triggeredBy])
  @@index([status])
  @@index([triggeredByUserId])
  @@map("email_logs")
}

model CronLog {
  id             String   @id @default(cuid())
  executedAt     DateTime @default(now())
  jobName        String
  jobType        String
  status         String
  duration       Int?
  totalProcessed Int      @default(0)
  totalAffected  Int      @default(0)
  metadata       Json?
  errorMessage   String?
  errorStack     String?

  @@index([executedAt])
  @@index([jobName])
  @@index([jobType])
  @@index([status])
  @@map("cron_logs")
}

enum UserRole {
  ADMIN
  AGENT
  COMMERCIAL
}

enum SimulationStatus {
  DRAFT
  SHARED
  EXPIRED
}

enum BaseValueScope {
  GLOBAL
  AGENCY
}
