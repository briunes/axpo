// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// DOMAIN ENTITIES
// ============================================================================

model Agency {
  id           String     @id @default(cuid())
  name         String
  street       String?    // Address line
  city         String?
  postalCode   String?
  province     String?
  country      String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  users               User[]
  simulations         Simulation[]
  baseValueSets       BaseValueSet[]
  clients             Client[]

  @@map("agencies")
}

model Client {
  id           String    @id @default(cuid())
  agencyId     String
  agency       Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name         String
  cif          String?   // Company tax number / VAT ID
  contactName  String?   // Main contact person
  contactEmail String?
  contactPhone String?
  otherDetails String?
  isActive     Boolean   @default(true)
  isDeleted    Boolean      @default(false)
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  simulations Simulation[]

  @@map("clients")
}

model User {
  id             String   @id @default(cuid())
  agencyId       String
  agency         Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  
  role           UserRole @default(COMMERCIAL)
  fullName       String
  email          String   @unique
  mobilePhone    String?
  commercialPhone String?
  commercialEmail String?
  otherDetails   String?
  passwordHash   String?  // Internal authentication password hash
  pinHash        String   // Global PIN (hashed only, visible in backoffice as masked PIN for client sharing)
  pinCurrent     String?  // Plaintext PIN stored for display in backoffice (set at creation/rotation)
  pinRotatedAt   DateTime @default(now())
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdByUserId String?
  createdByUser   User?    @relation("UserCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId String?
  updatedByUser   User?    @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  // Relations
  simulations         Simulation[]
  simulationVersions  SimulationVersion[]
  baseValueSets       BaseValueSet[]
  auditLogs           AuditLog[]
  createdUsers        User[]   @relation("UserCreatedBy")
  updatedUsers        User[]   @relation("UserUpdatedBy")

  @@map("users")
}

enum UserRole {
  ADMIN
  AGENT
  COMMERCIAL
}

model Simulation {
  id               String   @id @default(cuid())
  agencyId         String
  agency           Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  
  ownerUserId      String
  ownerUser        User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  clientId         String?
  client           Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  status           SimulationStatus @default(DRAFT)
  expiresAt        DateTime?
  publicToken      String?  @unique // Random long token for public access
  pinHashSnapshot  String?  // PIN snapshot at share time (allows clients to access even after user PIN rotation)
  pinSnapshot      String?  // Plaintext PIN at snapshot time (for backoffice display)
  isDeleted        Boolean  @default(false) // Soft delete
  deletedAt        DateTime?
  sharedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  versions         SimulationVersion[]
  accessAttempts   AccessAttempt[]

  @@map("simulations")
}

enum SimulationStatus {
  DRAFT
  SHARED
  EXPIRED
}

model SimulationVersion {
  id               String   @id @default(cuid())
  simulationId     String
  simulation       Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  
  payloadJson      Json     // Simulation data snapshot (immutable)
  baseValueSetId   String?  // Reference to base values used in calculation (optional, nullable)
  baseValueSet     BaseValueSet? @relation(fields: [baseValueSetId], references: [id], onDelete: SetNull)
  
  createdBy        String
  createdByUser    User     @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt        DateTime @default(now())

  @@map("simulation_versions")
}

model BaseValueSet {
  id               String   @id @default(cuid())
  scopeType        BaseValueScope @default(GLOBAL)
  agencyId         String?  // Nullable when GLOBAL scope
  agency           Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  
  name             String
  sourceWorkbookRef String? // XLSX source snapshot reference/version
  sourceScope      String?  // Sheet group or domain family (e.g., "GAS_TARIFFS", "OMIE")
  version          Int      @default(1)
  
  isActive         Boolean  @default(true)
  isDeleted        Boolean  @default(false) // Soft delete
  deletedAt        DateTime?
  
  createdBy        String
  createdByUser    User     @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  items            BaseValueItem[]
  simulationVersions SimulationVersion[]

  @@map("base_value_sets")
}

enum BaseValueScope {
  GLOBAL
  AGENCY
}

model BaseValueItem {
  id               String   @id @default(cuid())
  baseValueSetId   String
  baseValueSet     BaseValueSet @relation(fields: [baseValueSetId], references: [id], onDelete: Cascade)
  
  key              String   // e.g., "TARIFF_GAS_JAN", "OMIE_DYN_FEB"
  valueNumeric     Decimal? // Numeric values
  valueText        String?  // Text/categorical values
  unit             String?  // Unit (e.g., "EUR/MWh", "%")
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([baseValueSetId, key])
  @@map("base_value_items")
}

model AccessAttempt {
  id               String   @id @default(cuid())
  simulationId     String
  simulation       Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  
  tokenFragment    String?  // First 8 chars of token for logging (hash not token itself)
  ipHashOrMask     String?  // IP hash or masked IP for logging
  success          Boolean
  reason           String?  // "INVALID_PIN", "RATE_LIMIT", "EXPIRED", "SUCCESS", etc.
  
  createdAt        DateTime @default(now())

  @@map("access_attempts")
}

model AuditLog {
  id               String   @id @default(cuid())
  actorUserId      String?  // Nullable for public access events
  actor            User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  
  eventType        String   // e.g., "SIMULATION_CREATED", "PIN_ROTATED", "PUBLIC_ACCESS", "SOFT_DELETE"
  targetType       String   // e.g., "SIMULATION", "USER", "BASE_VALUE_SET"
  targetId         String   // ID of the affected entity
  
  metadataJson     Json?    // Additional context (changes, values, etc.)
  
  createdAt        DateTime @default(now())

  @@map("audit_logs")
}

// ============================================================================
// CONFIGURATION ENTITIES
// ============================================================================

model SystemConfig {
  id                        String   @id @default(cuid())
  
  // Simulation settings
  simulationExpirationDays  Int      @default(30)
  simulationShareText       String   @default("Your simulation is ready. Access it with PIN: {PIN}")
  enablePixelTracking       Boolean  @default(true)
  
  // User & Auth settings
  requirePinForAccess       Boolean  @default(true)
  pinLength                 Int      @default(4)
  
  // Client settings
  autoCreateClientOnSim     Boolean  @default(false)
  
  // Module settings
  enableAnalyticsModule     Boolean  @default(true)
  enableAuditLogsModule     Boolean  @default(true)
  
  // Dashboard settings
  defaultDashboardView      String   @default("COMMERCIAL") // ADMIN, MASTER, COMMERCIAL
  enableRealtimeReports     Boolean  @default(false)
  
  // SMTP Email settings
  smtpHost                  String?
  smtpPort                  Int?     @default(587)
  smtpSecure                Boolean  @default(false)
  smtpUser                  String?
  smtpPassword              String?
  smtpFromEmail             String?
  smtpFromName              String?  @default("Axpo Simulator")
  
  // Email template settings for automated emails
  userCreationEmailTemplateId  String?  // Template to use when creating new users
  
  updatedAt                 DateTime @updatedAt
  createdAt                 DateTime @default(now())

  @@map("system_config")
}

model PdfTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  type        String   // simulation-output, simulation-detailed, contract, price-history, invoice, report
  active      Boolean  @default(true)
  htmlContent String   @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pdf_templates")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  type        String   // simulation-share, magic-link, welcome, password-reset, expiring-soon, converted, notification
  active      Boolean  @default(true)
  subject     String
  htmlContent String   @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

model RolePermission {
  id            String   @id @default(cuid())
  role          UserRole
  permissionKey String
  allowed       Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([role, permissionKey])
  @@map("role_permissions")
}

model TemplateVariable {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., "CLIENT_NAME", "SIMULATION_ID"
  label       String   // Display name for UI
  description String?  // Description for users
  category    String   // "client", "simulation", "user", "calculation", "period"
  example     String?  // Example value
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("template_variables")
}
