generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agency {
  id                   String                @id @default(cuid())
  name                 String
  isActive             Boolean               @default(true)
  isTlv                Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  street               String?
  city                 String?
  postalCode           String?
  province             String?
  country              String?
  deletedAt            DateTime?
  isDeleted            Boolean               @default(false)
  createdByUserId      String?
  updatedByUserId      String?
  createdByUser        User?                 @relation("AgencyCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser        User?                 @relation("AgencyUpdatedBy", fields: [updatedByUserId], references: [id])
  agencyProductConfigs AgencyProductConfig[]
  agencyTariffs        AgencyTariff[]
  baseValueSets        BaseValueSet[]
  clients              Client[]
  simulations          Simulation[]
  users                User[]
  ocrUsageInvoices     OcrUsageInvoice[]

  @@index([isDeleted])
  @@map("agencies")
}

model AgencyTariff {
  id         String   @id @default(cuid())
  agencyId   String
  tariffType String
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  agency     Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, tariffType])
  @@map("agency_tariffs")
}

model AgencyProductConfig {
  id          String   @id @default(cuid())
  agencyId    String
  productKey  String
  commodity   String   @default("ELECTRICITY")
  pricingType String   @default("FIXED")
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, commodity, pricingType, productKey])
  @@map("agency_product_configs")
}

model Client {
  id               String            @id @default(cuid())
  agencyId         String
  name             String
  isActive         Boolean           @default(true)
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  cif              String?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  otherDetails     String?
  street           String?
  city             String?
  postalCode       String?
  province         String?
  country          String?
  language         String?
  createdByUserId  String?
  updatedByUserId  String?
  agency           Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdByUser    User?             @relation("ClientCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser    User?             @relation("ClientUpdatedBy", fields: [updatedByUserId], references: [id])
  simulations      Simulation[]
  ocrUsageInvoices OcrUsageInvoice[]

  @@index([agencyId, isDeleted])
  @@map("clients")
}

model User {
  id                          String              @id @default(cuid())
  agencyId                    String
  role                        UserRole            @default(COMMERCIAL)
  fullName                    String
  email                       String              @unique
  pinHash                     String
  pinRotatedAt                DateTime            @default(now())
  isActive                    Boolean             @default(true)
  maxActiveDevices            Int                 @default(3)
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  passwordHash                String?
  mobilePhone                 String?
  commercialPhone             String?
  commercialEmail             String?
  otherDetails                String?
  pinCurrent                  String?
  createdByUserId             String?
  updatedByUserId             String?
  setupToken                  String?             @unique
  setupTokenExpiresAt         DateTime?
  passwordResetToken          String?             @unique
  passwordResetTokenExpiresAt DateTime?
  magicLinkToken              String?             @unique
  magicLinkTokenExpiresAt     DateTime?
  otpCode                     String?
  otpCodeExpiresAt            DateTime?
  otpSessionToken             String?             @unique
  otpSessionTokenExpiresAt    DateTime?
  otpSecret                   String?
  deletedAt                   DateTime?
  isDeleted                   Boolean             @default(false)
  createdAgencies             Agency[]            @relation("AgencyCreatedBy")
  updatedAgencies             Agency[]            @relation("AgencyUpdatedBy")
  auditLogs                   AuditLog[]
  baseValueSets               BaseValueSet[]
  createdClients              Client[]            @relation("ClientCreatedBy")
  updatedClients              Client[]            @relation("ClientUpdatedBy")
  triggeredEmailLogs          EmailLog[]
  ocrLogs                     OcrLog[]
  llmBenchmarkRuns            LlmBenchmarkRun[]
  sessions                    UserSession[]       @relation("UserSessions")
  terminatedSessions          UserSession[]       @relation("SessionTerminatedBy")
  simulationVersions          SimulationVersion[]
  simulations                 Simulation[]
  preferences                 UserPreferences?
  appErrorLogs                AppErrorLog[]
  ocrPricesCreated            OcrModelPrice[]     @relation("OcrPriceCreatedBy")
  ocrPricesUpdated            OcrModelPrice[]     @relation("OcrPriceUpdatedBy")
  ocrInvoicesCreated          OcrUsageInvoice[]   @relation("OcrInvoiceCreatedBy")
  ocrInvoicesAsUser           OcrUsageInvoice[]   @relation("OcrInvoiceUser")
  audienceNotifications       Notification[]      @relation("NotificationAudienceUser")
  notificationReads           NotificationRead[]
  agency                      Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdByUser               User?               @relation("UserCreatedBy", fields: [createdByUserId], references: [id])
  createdUsers                User[]              @relation("UserCreatedBy")
  updatedByUser               User?               @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id])
  updatedUsers                User[]              @relation("UserUpdatedBy")

  @@index([agencyId, isDeleted])
  @@index([email, isDeleted])
  @@map("users")
}

model UserSession {
  id                 String    @id @default(cuid())
  userId             String
  sessionTokenId     String    @unique
  deviceFingerprint  String
  ipAddress          String?
  userAgent          String?
  browser            String?
  os                 String?
  authMethod         String
  loginAt            DateTime  @default(now())
  lastActivityAt     DateTime  @default(now())
  logoutAt           DateTime?
  isActive           Boolean   @default(true)
  terminationReason  String?
  terminatedByUserId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  metadataJson       Json?
  user               User      @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  terminatedByUser   User?     @relation("SessionTerminatedBy", fields: [terminatedByUserId], references: [id])

  @@index([userId, isActive, loginAt])
  @@index([isActive, lastActivityAt])
  @@index([deviceFingerprint])
  @@map("user_sessions")
}

model UserPreferences {
  id           String   @id @default(cuid())
  userId       String   @unique
  language     String?
  dateFormat   String?
  timeFormat   String?
  timezone     String?
  numberFormat String?
  itemsPerPage Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Simulation {
  id                  String              @id @default(cuid())
  referenceNumber     String?             @unique
  agencyId            String
  ownerUserId         String
  status              SimulationStatus    @default(DRAFT)
  expiresAt           DateTime?
  publicToken         String?             @unique
  pinHashSnapshot     String?
  isDeleted           Boolean             @default(false)
  deletedAt           DateTime?
  sharedAt            DateTime?
  clientOpenedAt      DateTime?
  sharedVia           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  clientId            String?
  pinSnapshot         String?
  invoiceFilePath     String?
  invoiceFileData     Bytes?
  invoiceFileMimeType String?
  invoiceFileName     String?
  invoiceFileSize     Int?
  accessAttempts      AccessAttempt[]
  ocrLogs             OcrLog[]
  versions            SimulationVersion[]
  agency              Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client              Client?             @relation(fields: [clientId], references: [id])
  ownerUser           User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([agencyId, isDeleted, updatedAt(sort: Desc)])
  @@index([ownerUserId, isDeleted, updatedAt(sort: Desc)])
  @@index([status, isDeleted])
  @@map("simulations")
}

model SimulationVersion {
  id             String        @id @default(cuid())
  simulationId   String
  payloadJson    Json
  baseValueSetId String?
  createdBy      String
  createdAt      DateTime      @default(now())
  baseValueSet   BaseValueSet? @relation(fields: [baseValueSetId], references: [id])
  createdByUser  User          @relation(fields: [createdBy], references: [id])
  simulation     Simulation    @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@index([simulationId, createdAt(sort: Desc)])
  @@map("simulation_versions")
}

model BaseValueSet {
  id                 String              @id @default(cuid())
  scopeType          BaseValueScope      @default(GLOBAL)
  agencyId           String?
  name               String
  sourceWorkbookRef  String?
  sourceScope        String?
  version            Int                 @default(1)
  isActive           Boolean             @default(true)
  isDeleted          Boolean             @default(false)
  deletedAt          DateTime?
  createdBy          String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isProduction       Boolean             @default(false)
  sourceFileName     String?
  sourceFileData     Bytes?
  items              BaseValueItem[]
  agency             Agency?             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdByUser      User                @relation(fields: [createdBy], references: [id])
  simulationVersions SimulationVersion[]

  @@map("base_value_sets")
}

model BaseValueItem {
  id             String       @id @default(cuid())
  baseValueSetId String
  key            String
  valueNumeric   Decimal?
  valueText      String?
  unit           String?
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  baseValueSet   BaseValueSet @relation(fields: [baseValueSetId], references: [id], onDelete: Cascade)

  @@unique([baseValueSetId, key])
  @@map("base_value_items")
}

model ExcelParserProductConfig {
  id             String         @id @default(cuid())
  scopeType      BaseValueScope
  sourceLabel    String
  productKey     String
  displayName    String
  commodity      String
  pricingType    String
  enabled        Boolean        @default(true)
  singlePeriod   Boolean        @default(false)
  eligibilityMin Decimal?
  eligibilityMax Decimal?
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([scopeType, sourceLabel])
  @@index([scopeType, commodity, pricingType, enabled, sortOrder])
  @@map("excel_parser_product_configs")
}

model AccessAttempt {
  id            String     @id @default(cuid())
  simulationId  String
  tokenFragment String?
  ipHashOrMask  String?
  success       Boolean
  reason        String?
  createdAt     DateTime   @default(now())
  simulation    Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@map("access_attempts")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  eventType    String
  targetType   String
  targetId     String
  metadataJson Json?
  createdAt    DateTime @default(now())
  actor        User?    @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model SystemConfig {
  id                              String    @id @default(cuid())
  simulationExpirationDays        Int       @default(30)
  simulationShareText             String    @default("Your simulation is ready. Access it with PIN: {PIN}")
  enablePixelTracking             Boolean   @default(true)
  requirePinForAccess             Boolean   @default(true)
  pinLength                       Int       @default(4)
  autoCreateClientOnSim           Boolean   @default(false)
  enableAnalyticsModule           Boolean   @default(true)
  enableAuditLogsModule           Boolean   @default(true)
  defaultDashboardView            String    @default("COMMERCIAL")
  enableRealtimeReports           Boolean   @default(false)
  updatedAt                       DateTime  @updatedAt
  createdAt                       DateTime  @default(now())
  smtpFromEmail                   String?
  smtpFromName                    String?   @default("Axpo Simulator")
  smtpHost                        String?
  smtpPassword                    String?
  smtpPort                        Int?      @default(587)
  smtpSecure                      Boolean   @default(false)
  smtpUser                        String?
  userCreationEmailTemplateId     String?
  electricityTaxRate              Decimal   @default(0.051127)
  ivaRate                         Decimal   @default(0.21)
  defaultDateFormat               String    @default("DD/MM/YYYY")
  defaultItemsPerPage             Int       @default(10)
  defaultLanguage                 String    @default("en")
  defaultNumberFormat             String    @default("eu")
  defaultTimeFormat               String    @default("24h")
  defaultTimezone                 String    @default("Europe/Madrid")
  llmApiKey                       String?
  llmBaseUrl                      String?
  llmEnabled                      Boolean   @default(false)
  llmMaxTokens                    Int?      @default(2000)
  llmModelName                    String?   @default("llama3.2")
  llmProvider                     String?   @default("ollama")
  llmTemperature                  Decimal?  @default(0.1)
  aiProviderConfigs               Json?
  aiTaskConfigs                   Json?
  setupTokenValidityHours         Int       @default(72)
  passwordResetEmailTemplateId    String?
  passwordResetTokenValidityHours Int       @default(24)
  magicLinkEnabled                Boolean   @default(false)
  magicLinkEmailTemplateId        String?
  magicLinkTokenValidityMinutes   Int       @default(15)
  otpEnabled                      Boolean   @default(false)
  otpEmailTemplateId              String?
  otpCodeValidityMinutes          Int       @default(10)
  defaultMaxActiveDevices         Int       @default(3)
  defaultPdfTemplateElectricityId String?
  defaultPdfTemplateGasId         String?
  maxUploadFileSizeMb             Int       @default(15)
  cronExpirationEnabled           Boolean   @default(true)
  cronExpirationSchedule          String    @default("0 2 * * *")
  cronExpirationTimezone          String    @default("UTC")
  hydrocarbonTaxRate              Decimal   @default(0.00234)
  ivaRateOptions                  Json?
  electricityTaxRateOptions       Json?
  hydrocarbonTaxRateOptions       Json?
  electricityTaxConfig            Json?
  gasTaxConfig                    Json?
  appVersion                      String    @default("0.2.1")
  appChangelog                    Json?
  maintenanceMode                 Boolean   @default(false)
  maintenanceUntil                DateTime?
  maintenanceMessage              String?
  ocrBillingEnabled               Boolean   @default(false)
  ocrBillingCurrency              String    @default("USD")
  ocrBillingUnitTokens            Int       @default(1000)
  ocrBillingMarkupPercent         Decimal   @default(0)
  ocrBillingFixedFeePerCall       Decimal   @default(0)
  ocrBillingIncludeFailedCalls    Boolean   @default(false)
  requestCacheConfig              Json?

  @@map("system_config")
}

model PdfTemplate {
  id               String                   @id @default(cuid())
  name             String
  description      String
  type             String
  active           Boolean                  @default(true)
  htmlContent      String
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  editableSections Json?
  deletedAt        DateTime?
  isDeleted        Boolean                  @default(false)
  commodity        String?
  translations     PdfTemplateTranslation[]

  @@map("pdf_templates")
}

model PdfTemplateTranslation {
  id            String      @id @default(cuid())
  pdfTemplateId String
  languageCode  String
  htmlContent   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  pdfTemplate   PdfTemplate @relation(fields: [pdfTemplateId], references: [id], onDelete: Cascade)

  @@unique([pdfTemplateId, languageCode])
  @@map("pdf_template_translations")
}

model EmailTemplate {
  id               String                     @id @default(cuid())
  name             String
  description      String
  type             String
  active           Boolean                    @default(true)
  subject          String
  htmlContent      String
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  editableSections Json?
  deletedAt        DateTime?
  isDeleted        Boolean                    @default(false)
  translations     EmailTemplateTranslation[]

  @@map("email_templates")
}

model EmailTemplateTranslation {
  id              String        @id @default(cuid())
  emailTemplateId String
  languageCode    String
  subject         String
  htmlContent     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  emailTemplate   EmailTemplate @relation(fields: [emailTemplateId], references: [id], onDelete: Cascade)

  @@unique([emailTemplateId, languageCode])
  @@map("email_template_translations")
}

model RolePermission {
  id            String   @id @default(cuid())
  role          UserRole
  permissionKey String
  allowed       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([role, permissionKey])
  @@map("role_permissions")
}

model Notification {
  id             String                 @id @default(cuid())
  type           String
  category       String
  severity       NotificationSeverity   @default(INFO)
  title          String
  body           String?
  audienceRole   UserRole?
  audienceUserId String?
  sourceType     String?
  sourceId       String?
  dedupeKey      String                 @unique
  actionUrl      String?
  metadata       Json?
  firstSeenAt    DateTime               @default(now())
  lastSeenAt     DateTime               @default(now())
  resolvedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  audienceUser   User?                  @relation("NotificationAudienceUser", fields: [audienceUserId], references: [id], onDelete: Cascade)
  reads          NotificationRead[]

  @@index([audienceRole, resolvedAt, lastSeenAt(sort: Desc)])
  @@index([audienceUserId, resolvedAt, lastSeenAt(sort: Desc)])
  @@index([category, severity])
  @@index([sourceType, sourceId])
  @@map("notifications")
}

model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, dismissedAt])
  @@map("notification_reads")
}

model TemplateVariable {
  id            String    @id @default(cuid())
  key           String    @unique
  label         String
  description   String?
  category      String
  example       String?
  sortOrder     Int       @default(0)
  active        Boolean   @default(true)
  /// Comma-separated template types this variable applies to (null = all types)
  templateTypes String?
  /// Commodity this variable applies to: ELECTRICITY, GAS (null = all commodities)
  commodity     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  isDeleted     Boolean   @default(false)

  @@map("template_variables")
}

model EmailLog {
  id                  String   @id @default(cuid())
  sentAt              DateTime @default(now())
  recipientEmail      String
  templateId          String?
  templateName        String?
  subject             String
  htmlBody            String
  triggeredBy         String?
  triggeredByUserId   String?
  variables           Json?
  status              String   @default("sent")
  errorMessage        String?
  errorStack          String?
  relatedUserId       String?
  relatedSimulationId String?
  // SMTP delivery details
  smtpHost            String?
  smtpPort            Int?
  fromEmail           String?
  fromName            String?
  messageId           String?
  smtpResponse        String?
  durationMs          Int?
  hasAttachments      Boolean  @default(false)
  attachmentsCount    Int      @default(0)
  triggeredByUser     User?    @relation(fields: [triggeredByUserId], references: [id])

  @@index([sentAt])
  @@index([recipientEmail])
  @@index([triggeredBy])
  @@index([status])
  @@index([triggeredByUserId])
  @@map("email_logs")
}

model CronLog {
  id             String   @id @default(cuid())
  executedAt     DateTime @default(now())
  jobName        String
  jobType        String
  status         String
  duration       Int?
  totalProcessed Int      @default(0)
  totalAffected  Int      @default(0)
  metadata       Json?
  errorMessage   String?
  errorStack     String?

  @@index([executedAt])
  @@index([jobName])
  @@index([jobType])
  @@index([status])
  @@map("cron_logs")
}

model InvoiceProviderPrompt {
  id                String   @id @default(cuid())
  name              String // e.g. "Repsol", "NEON", "Iberdrola"
  slug              String   @unique // e.g. "repsol", "neon", "iberdrola"
  prompt            String   @db.Text // Legacy generic prompt (kept for backward compatibility)
  promptElectricity String   @default("") @db.Text // Custom prompt for electricity invoices
  promptGas         String   @default("") @db.Text // Custom prompt for gas invoices
  isActive          Boolean  @default(true)
  needsPromptConfig Boolean  @default(false) // true when auto-created from simulation (prompt not yet configured)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("invoice_provider_prompts")
}

model OcrLog {
  id                   String       @id @default(cuid())
  requestedAt          DateTime     @default(now())
  userId               String?
  userEmail            String?
  simulationId         String?
  type                 OcrLogType   @default(INVOICE_EXTRACTION)
  provider             String
  model                String
  baseUrl              String?
  fileName             String?
  fileType             String?
  fileSizeBytes        Int?
  pageCount            Int?
  status               String // SUCCESS | FAILED | ERROR | PARSE_ERROR
  durationMs           Int?
  promptTokens         Int?
  completionTokens     Int?
  totalTokens          Int?
  extractedFields      Json? // the extracted JSON data (sanitized, no PII beyond what was extracted)
  fieldsExtracted      Int? // count of non-null fields
  userCorrections      Json? // corrections applied by the user: { fieldName: { ocr: value, corrected: value } }
  errorMessage         String?
  errorType            String?
  httpStatusCode       Int?
  rawResponseSnippet   String? // first 500 chars of response for debugging
  promptText           String?      @db.Text // the full prompt sent to the LLM
  metadata             Json? // any extra provider-specific info
  reportedIssue        String? // user-reported issue message when extraction is mostly empty
  issueStatus          String? // OPEN | IN_PROGRESS | RESOLVED | DISMISSED
  issueResolution      String?
  issueNotes           String?      @db.Text
  issueSubmittedAt     DateTime?
  issueHandledAt       DateTime?
  issueHandledByUserId String?
  user                 User?        @relation(fields: [userId], references: [id])
  simulation           Simulation?  @relation(fields: [simulationId], references: [id], onDelete: SetNull)
  ocrFiles             OcrLogFile[]

  @@index([requestedAt])
  @@index([userId])
  @@index([simulationId])
  @@index([provider])
  @@index([status])
  @@index([type])
  @@index([issueStatus])
  @@map("ocr_logs")
}

model OcrLogFile {
  id            String   @id @default(cuid())
  ocrLogId      String
  fileName      String
  fileType      String?
  fileSizeBytes Int
  fileData      Bytes
  createdAt     DateTime @default(now())
  ocrLog        OcrLog   @relation(fields: [ocrLogId], references: [id], onDelete: Cascade)

  @@index([ocrLogId])
  @@map("ocr_log_files")
}

model LlmBenchmarkRun {
  id                         String   @id @default(cuid())
  benchmarkRunId             String?
  providerConfigId           String
  providerName               String
  provider                   String
  modelName                  String
  benchmarkFileName          String
  status                     String
  detectionSuccess           Boolean
  detectionScore             Int
  detectionDurationMs        Int
  detectionPromptTokens      Int?
  detectionCompletionTokens  Int?
  detectionTotalTokens       Int?
  detectionCorrectFields     Int
  detectionTotalFields       Int
  detectionResult            Json?
  detectionFieldScores       Json?
  detectionError             String?
  extractionSuccess          Boolean
  extractionScore            Int
  extractionDurationMs       Int
  extractionPromptTokens     Int?
  extractionCompletionTokens Int?
  extractionTotalTokens      Int?
  extractionCorrectFields    Int
  extractionTotalFields      Int
  extractionResult           Json?
  extractionFieldScores      Json?
  extractionError            String?
  overallScore               Int
  totalDurationMs            Int
  totalTokens                Int?
  createdByUserId            String?
  createdAt                  DateTime @default(now())
  createdByUser              User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([benchmarkRunId, createdAt(sort: Desc)])
  @@index([providerConfigId, createdAt(sort: Desc)])
  @@index([provider, modelName])
  @@index([createdAt(sort: Desc)])
  @@map("llm_benchmark_runs")
}

enum OcrLogType {
  INVOICE_EXTRACTION
  PROVIDER_DETECTION
  PROMPT_IMPROVEMENT
  PROMPT_TEST
  TEMPLATE_BUILDER
}

enum UserRole {
  SYS_ADMIN
  ADMIN
  AGENT
  COMMERCIAL
}

enum SimulationStatus {
  DRAFT
  SHARED
  EXPIRED
}

enum BaseValueScope {
  GLOBAL
  AGENCY
  TLV
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
  CRITICAL
}

model AppErrorLog {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Error details
  errorType String // e.g. "Error", "ZodError", "DomainError"
  errorCode String? // domain error code, e.g. "NOT_FOUND"
  message   String
  stack     String?

  // HTTP context
  method     String? // GET, POST, etc.
  path       String? // /api/v1/internal/...
  pagePath   String? // Browser route where the API request originated
  statusCode Int?

  // Who triggered it (optional — may be unauthenticated)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Sentry event ID for cross-referencing
  sentryEventId String?

  // Extra metadata (JSON)
  metadata Json?

  @@index([createdAt])
  @@index([errorType])
  @@index([path])
  @@index([pagePath])
  @@index([userId])
  @@index([isDeleted, createdAt(sort: Desc)])
  @@map("app_error_logs")
}

model OcrModelPrice {
  id                     String    @id @default(cuid())
  provider               String
  model                  String
  inputPricePer1kTokens  Decimal   @db.Decimal(18, 8)
  outputPricePer1kTokens Decimal   @db.Decimal(18, 8)
  currency               String    @default("USD")
  unitTokens             Int       @default(1000)
  isActive               Boolean   @default(true)
  effectiveFrom          DateTime  @default(now())
  effectiveTo            DateTime?
  note                   String?
  createdByUserId        String?
  updatedByUserId        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  createdByUser User? @relation("OcrPriceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("OcrPriceUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([model])
  @@index([isActive])
  @@map("ocr_model_prices")
}

model OcrUsageInvoice {
  id                    String   @id @default(cuid())
  label                 String
  periodStart           DateTime
  periodEnd             DateTime
  clientId              String?
  clientName            String?
  agencyId              String?
  userId                String?
  currency              String   @default("USD")
  totalCalls            Int      @default(0)
  successfulCalls       Int      @default(0)
  failedCalls           Int      @default(0)
  totalPromptTokens     BigInt   @default(0)
  totalCompletionTokens BigInt   @default(0)
  totalTokens           BigInt   @default(0)
  baseCost              Decimal  @default(0) @db.Decimal(18, 6)
  markupCost            Decimal  @default(0) @db.Decimal(18, 6)
  fixedFeeCost          Decimal  @default(0) @db.Decimal(18, 6)
  totalCost             Decimal  @default(0) @db.Decimal(18, 6)
  breakdown             Json?
  status                String   @default("DRAFT") // DRAFT | ISSUED | PAID | VOID
  note                  String?
  createdByUserId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  createdByUser User?   @relation("OcrInvoiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  client        Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  agency        Agency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  user          User?   @relation("OcrInvoiceUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([periodStart])
  @@index([periodEnd])
  @@index([clientId])
  @@index([status])
  @@map("ocr_usage_invoices")
}
