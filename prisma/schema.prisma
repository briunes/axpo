// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// DOMAIN ENTITIES
// ============================================================================

model Agency {
  id           String     @id @default(cuid())
  name         String
  street       String?    // Address line
  city         String?
  postalCode   String?
  province     String?
  country      String?
  isActive     Boolean    @default(true)
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  users               User[]
  simulations         Simulation[]
  baseValueSets       BaseValueSet[]
  clients             Client[]
  agencyTariffs       AgencyTariff[]

  @@map("agencies")
}

model AgencyTariff {
  id           String   @id @default(cuid())
  agencyId     String
  agency       Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  
  tariffType   String   // "ELEC:2.0TD", "ELEC:3.0TD", "ELEC:6.1TD", "GAS:RL01", etc.
  isEnabled    Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([agencyId, tariffType])
  @@map("agency_tariffs")
}

model Client {
  id           String    @id @default(cuid())
  agencyId     String
  agency       Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name         String
  cif          String?   // Company tax number / VAT ID
  contactName  String?   // Main contact person
  contactEmail String?
  contactPhone String?
  otherDetails String?
  isActive     Boolean   @default(true)
  isDeleted    Boolean      @default(false)
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  simulations Simulation[]

  @@map("clients")
}

model User {
  id             String   @id @default(cuid())
  agencyId       String
  agency         Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  
  role           UserRole @default(COMMERCIAL)
  fullName       String
  email          String   @unique
  mobilePhone    String?
  commercialPhone String?
  commercialEmail String?
  otherDetails   String?
  passwordHash                String?   // Internal authentication password hash
  setupToken                  String?   @unique // One-time token for first-time password setup
  setupTokenExpiresAt         DateTime? // Expiry for the setup token (72 hours from user creation)
  passwordResetToken          String?   @unique // One-time token for password reset
  passwordResetTokenExpiresAt DateTime? // Expiry for the password reset token
  pinHash        String   // Global PIN (hashed only, visible in backoffice as masked PIN for client sharing)
  pinCurrent     String?  // Plaintext PIN stored for display in backoffice (set at creation/rotation)
  pinRotatedAt   DateTime @default(now())
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdByUserId String?
  createdByUser   User?    @relation("UserCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId String?
  updatedByUser   User?    @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  // Relations
  simulations         Simulation[]
  simulationVersions  SimulationVersion[]
  baseValueSets       BaseValueSet[]
  auditLogs           AuditLog[]
  triggeredEmailLogs  EmailLog[]   // Emails triggered by this user
  createdUsers        User[]   @relation("UserCreatedBy")
  updatedUsers        User[]   @relation("UserUpdatedBy")
  preferences         UserPreferences?

  @@map("users")
}

model UserPreferences {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Display preferences (null = use system default)
  dateFormat       String?  // DD/MM/YYYY, MM/DD/YYYY, YYYY-MM-DD
  timeFormat       String?  // 12h, 24h
  timezone         String?  // Europe/Madrid, America/New_York, etc.
  numberFormat     String?  // eu (1.234,56), us (1,234.56)
  itemsPerPage     Int?     // Pagination preference
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("user_preferences")
}

enum UserRole {
  ADMIN
  AGENT
  COMMERCIAL
}

model Simulation {
  id               String   @id @default(cuid())
  agencyId         String
  agency           Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  
  ownerUserId      String
  ownerUser        User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  clientId         String?
  client           Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  status           SimulationStatus @default(DRAFT)
  expiresAt        DateTime?
  publicToken      String?  @unique // Random long token for public access
  pinHashSnapshot  String?  // PIN snapshot at share time (allows clients to access even after user PIN rotation)
  pinSnapshot      String?  // Plaintext PIN at snapshot time (for backoffice display)
  invoiceFilePath  String?  // Path to uploaded invoice file (deprecated - use invoiceFileData)
  invoiceFileData  Bytes?   // Invoice file binary data
  invoiceFileName  String?  // Original invoice filename
  invoiceFileMimeType String? // Invoice file MIME type (application/pdf, image/jpeg, etc.)
  invoiceFileSize  Int?     // Invoice file size in bytes
  isDeleted        Boolean  @default(false) // Soft delete
  deletedAt        DateTime?
  sharedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  versions         SimulationVersion[]
  accessAttempts   AccessAttempt[]

  @@map("simulations")
}

enum SimulationStatus {
  DRAFT
  SHARED
  EXPIRED
}

model SimulationVersion {
  id               String   @id @default(cuid())
  simulationId     String
  simulation       Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  
  payloadJson      Json     // Simulation data snapshot (immutable)
  baseValueSetId   String?  // Reference to base values used in calculation (optional, nullable)
  baseValueSet     BaseValueSet? @relation(fields: [baseValueSetId], references: [id], onDelete: SetNull)
  
  createdBy        String
  createdByUser    User     @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt        DateTime @default(now())

  @@map("simulation_versions")
}

model BaseValueSet {
  id               String   @id @default(cuid())
  scopeType        BaseValueScope @default(GLOBAL)
  agencyId         String?  // Nullable when GLOBAL scope
  agency           Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  
  name             String
  sourceWorkbookRef String? // XLSX source snapshot reference/version
  sourceScope      String?  // Sheet group or domain family (e.g., "GAS_TARIFFS", "OMIE")
  version          Int      @default(1)
  
  isActive         Boolean  @default(true)
  isProduction     Boolean  @default(false) // Production vs testing version control
  isDeleted        Boolean  @default(false) // Soft delete
  deletedAt        DateTime?
  
  createdBy        String
  createdByUser    User     @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  items            BaseValueItem[]
  simulationVersions SimulationVersion[]

  @@map("base_value_sets")
}

enum BaseValueScope {
  GLOBAL
  AGENCY
}

model BaseValueItem {
  id               String   @id @default(cuid())
  baseValueSetId   String
  baseValueSet     BaseValueSet @relation(fields: [baseValueSetId], references: [id], onDelete: Cascade)
  
  key              String   // e.g., "TARIFF_GAS_JAN", "OMIE_DYN_FEB"
  valueNumeric     Decimal? // Numeric values
  valueText        String?  // Text/categorical values
  unit             String?  // Unit (e.g., "EUR/MWh", "%")
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([baseValueSetId, key])
  @@map("base_value_items")
}

model AccessAttempt {
  id               String   @id @default(cuid())
  simulationId     String
  simulation       Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  
  tokenFragment    String?  // First 8 chars of token for logging (hash not token itself)
  ipHashOrMask     String?  // IP hash or masked IP for logging
  success          Boolean
  reason           String?  // "INVALID_PIN", "RATE_LIMIT", "EXPIRED", "SUCCESS", etc.
  
  createdAt        DateTime @default(now())

  @@map("access_attempts")
}

model AuditLog {
  id               String   @id @default(cuid())
  actorUserId      String?  // Nullable for public access events
  actor            User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  
  eventType        String   // e.g., "SIMULATION_CREATED", "PIN_ROTATED", "PUBLIC_ACCESS", "SOFT_DELETE"
  targetType       String   // e.g., "SIMULATION", "USER", "BASE_VALUE_SET"
  targetId         String   // ID of the affected entity
  
  metadataJson     Json?    // Additional context (changes, values, etc.)
  
  createdAt        DateTime @default(now())

  @@map("audit_logs")
}

// ============================================================================
// CONFIGURATION ENTITIES
// ============================================================================

model SystemConfig {
  id                        String   @id @default(cuid())
  
  // Simulation settings
  simulationExpirationDays  Int      @default(30)
  simulationShareText       String   @default("Your simulation is ready. Access it with PIN: {PIN}")
  enablePixelTracking       Boolean  @default(true)
  
  // Cron job settings
  cronExpirationEnabled     Boolean  @default(true)         // Enable/disable automatic expiration cron job
  cronExpirationSchedule    String   @default("0 2 * * *")  // Cron schedule expression (default: daily at 2 AM)
  cronExpirationTimezone    String   @default("UTC")        // Timezone for cron execution
  
  // User & Auth settings
  requirePinForAccess       Boolean  @default(true)
  pinLength                 Int      @default(4)
  
  // Client settings
  autoCreateClientOnSim     Boolean  @default(false)
  
  // Module settings
  enableAnalyticsModule     Boolean  @default(true)
  enableAuditLogsModule     Boolean  @default(true)
  
  // Dashboard settings
  defaultDashboardView      String   @default("COMMERCIAL") // ADMIN, MASTER, COMMERCIAL
  enableRealtimeReports     Boolean  @default(false)
  
  // SMTP Email settings
  smtpHost                  String?
  smtpPort                  Int?     @default(587)
  smtpSecure                Boolean  @default(false)
  smtpUser                  String?
  smtpPassword              String?
  smtpFromEmail             String?
  smtpFromName              String?  @default("Axpo Simulator")
  
  // Email template settings for automated emails
  userCreationEmailTemplateId  String?  // Template to use when creating new users
  passwordResetEmailTemplateId String?  // Template to use when resetting password
  
  // PDF template settings for simulations
  defaultPdfTemplateGasId      String?  // Default PDF template for gas simulations
  defaultPdfTemplateElectricityId String? // Default PDF template for electricity simulations
  
  // Password setup token settings
  setupTokenValidityHours   Int      @default(72)          // Hours before setup password token expires (default 72h = 3 days)
  passwordResetTokenValidityHours Int @default(24)         // Hours before password reset token expires (default 24h = 1 day)
  
  // Calculation formula parameters
  ivaRate                   Decimal  @default(0.21)        // IVA (VAT) rate (21%)
  electricityTaxRate        Decimal  @default(0.051127)    // Electricity tax rate (5.1127%)
  
  // System-wide user preference defaults
  defaultDateFormat         String   @default("DD/MM/YYYY")  // DD/MM/YYYY, MM/DD/YYYY, YYYY-MM-DD
  defaultTimeFormat         String   @default("24h")         // 12h, 24h
  defaultTimezone           String   @default("Europe/Madrid")
  defaultNumberFormat       String   @default("eu")          // eu (1.234,56), us (1,234.56)
  defaultItemsPerPage       Int      @default(10)            // Default pagination
  
  // LLM settings for simulation data extraction
  llmProvider               String?  @default("ollama")      // ollama, openai, anthropic, azure-openai, google, custom
  llmApiKey                 String?                          // API key for LLM service (not needed for Ollama)
  llmModelName              String?  @default("llama3.2")    // Model to use (e.g., llama3.2, gpt-4, claude-3-opus)
  llmBaseUrl                String?                          // Base URL for LLM API (for Ollama or custom endpoints)
  llmTemperature            Decimal? @default(0.1)           // Temperature for LLM responses (0.0-2.0)
  llmMaxTokens              Int?     @default(2000)          // Maximum tokens for LLM responses
  llmEnabled                Boolean  @default(false)         // Enable/disable LLM features
  
  updatedAt                 DateTime @updatedAt
  createdAt                 DateTime @default(now())

  @@map("system_config")
}

model PdfTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  type        String   // simulation-output, simulation-detailed, contract, price-history, invoice, report
  commodity   String?  // ELECTRICITY, GAS - filters which simulations can use this template
  active      Boolean  @default(true)
  htmlContent String   @db.Text
  editableSections Json? // Defines editable sections with defaults: {"INTRO_TEXT": {"label": "Intro", "default": "Default text", "multiline": true}}
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pdf_templates")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  type        String   // simulation-share, magic-link, welcome, password-reset, expiring-soon, converted, notification
  active      Boolean  @default(true)
  subject     String
  htmlContent String   @db.Text
  editableSections Json? // Defines editable sections with defaults: {"INTRO_TEXT": {"label": "Intro", "default": "Default text", "multiline": true}}
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

model RolePermission {
  id            String   @id @default(cuid())
  role          UserRole
  permissionKey String
  allowed       Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([role, permissionKey])
  @@map("role_permissions")
}

model TemplateVariable {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., "CLIENT_NAME", "SIMULATION_ID"
  label       String   // Display name for UI
  description String?  // Description for users
  category    String   // "client", "simulation", "user", "calculation", "period"
  example     String?  // Example value
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("template_variables")
}

model EmailLog {
  id                String   @id @default(cuid())
  sentAt            DateTime @default(now())
  
  // Recipient info
  recipientEmail    String
  
  // Email content
  templateId        String?
  templateName      String?
  subject           String
  htmlBody          String   @db.Text
  
  // Metadata - what triggered this email
  triggeredBy       String?  // e.g., "user-creation", "simulation-share", "test-email"
  triggeredByUserId String?
  triggeredByUser   User?    @relation(fields: [triggeredByUserId], references: [id])
  
  // Variables/payload used
  variables         Json?    // Store the template variables as JSON
  
  // Status
  status            String   @default("sent") // sent, failed
  errorMessage      String?  @db.Text
  
  // Associated records (for linking back to entities)
  relatedUserId     String?  // If related to a user (e.g., welcome email)
  relatedSimulationId String? // If related to a simulation (e.g., share email)
  
  @@map("email_logs")
  @@index([sentAt])
  @@index([recipientEmail])
  @@index([triggeredBy])
  @@index([status])
  @@index([triggeredByUserId])
}

model CronLog {
  id              String   @id @default(cuid())
  executedAt      DateTime @default(now())
  
  // Job identification
  jobName         String   // e.g., "simulation-expiration"
  jobType         String   // e.g., "EXPIRATION", "CLEANUP", "SYNC"
  
  // Execution status
  status          String   // "SUCCESS", "FAILED"
  
  // Execution details
  duration        Int?     // Duration in milliseconds
  totalProcessed  Int      @default(0) // Number of items processed
  totalAffected   Int      @default(0) // Number of items affected/expired/etc
  
  // Additional metadata
  metadata        Json?    // Store job-specific data (e.g., expired IDs, schedule, timezone)
  
  // Error information
  errorMessage    String?  @db.Text
  errorStack      String?  @db.Text
  
  @@map("cron_logs")
  @@index([executedAt])
  @@index([jobName])
  @@index([jobType])
  @@index([status])
}
