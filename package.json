{
  "name": "axpo-simulator-backend",
  "version": "0.2.0",
  "description": "AXPO Simulador de Ofertas - Backend API (NextJS)",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/sync-postman-artifacts.js && node scripts/generate-openapi.js && prisma generate && next build",
    "sync:postman": "node scripts/sync-postman-artifacts.js",
    "openapi:generate": "node scripts/generate-openapi.js",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "set -a && . ./.env.local && set +a && node ./scripts/seed-runtime.mjs",
    "db:import-prices": "set -a && . ./.env.local && set +a && node ./scripts/import-base-values.mjs",
    "db:import-prices:replace": "set -a && . ./.env.local && set +a && node ./scripts/import-base-values.mjs --replace",
    "db:studio": "prisma studio",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:security": "jest --testPathPattern=security"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^3.3.4",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^8.28.2",
    "@mui/x-data-grid": "^8.28.2",
    "@once-ui-system/core": "^1.6.4",
    "@prisma/client": "^5.7.1",
    "bcrypt": "5.1.1",
    "bcryptjs": "^3.0.3",
    "grapesjs": "^0.22.14",
    "grapesjs-preset-newsletter": "^1.0.2",
    "jsonwebtoken": "^9.0.2",
    "next": "16.1.4",
    "nodemailer": "^6.10.1",
    "puppeteer": "^24.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email-editor": "^1.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.11.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.1.4",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.16",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "prisma": "^5.7.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
