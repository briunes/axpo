{
  "name": "axpo-simulator-backend",
  "version": "0.2.1",
  "description": "AXPO Simulador de Ofertas - Backend API (NextJS)",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "rm -f .env.local && cp .env.local.example .env.local && next dev",
    "dev:dev": "rm -f .env.local && cp .env.dev .env.local && next dev",
    "dev:preview": "rm -f .env.local && cp .env.preview .env.local && next dev",
    "build": "node scripts/sync-postman-artifacts.js && node scripts/generate-openapi.js && prisma generate && next build",
    "sync:postman": "node scripts/sync-postman-artifacts.js",
    "openapi:generate": "node scripts/generate-openapi.js",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "set -a && . ./.env.local && set +a && node ./scripts/seed-runtime.mjs",
    "db:seed-notifications": "node ./scripts/seed-dev-notifications.mjs",
    "db:demo-cleanup": "set -a && . ./.env.local && set +a && node ./scripts/db-demo-cleanup.mjs",
    "db:import-prices": "set -a && . ./.env.local && set +a && node ./scripts/import-base-values.mjs",
    "db:import-prices:replace": "set -a && . ./.env.local && set +a && node ./scripts/import-base-values.mjs --replace",
    "db:studio": "prisma studio",
    "release:qld": "bash scripts/migrate-dev-to-qld.sh",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:security": "jest --testPathPattern=security"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@hookform/resolvers": "^3.3.4",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/material-nextjs": "^9.0.0",
    "@mui/x-charts": "^8.28.2",
    "@mui/x-data-grid": "^8.28.2",
    "@napi-rs/canvas": "^0.1.99",
    "@opendataloader/pdf": "2.4.7",
    "@prisma/client": "5.22.0",
    "@sentry/nextjs": "^10.59.0",
    "@sparticuz/chromium-min": "147.0.0",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-query-devtools": "^5.100.5",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "boneyard-js": "^1.9.0",
    "country-state-city": "^3.2.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "grapesjs": "^0.22.14",
    "grapesjs-preset-newsletter": "^1.0.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "3.10.1",
    "next": "16.2.9",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.20.0",
    "puppeteer-core": "25.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email-editor": "^1.8.0",
    "react-international-phone": "^4.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.32.6",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@next/eslint-plugin-next": "16.2.9",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "prisma": "^5.7.1",
    "puppeteer": "25.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "^7.29.7",
      "@opentelemetry/core": ">=2.8.0",
      "brace-expansion": ">=5.0.6",
      "dompurify": ">=3.4.11",
      "form-data": ">=4.0.6",
      "js-yaml": ">=4.2.0",
      "postcss": ">=8.5.10",
      "uuid": "11.1.1"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "core-js-pure",
      "prisma",
      "puppeteer",
      "sharp"
    ]
  }
}
