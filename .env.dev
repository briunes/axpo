# Development Environment Variables (Supabase DEV Database)

# Database
# SESSION POOLER (port 5432) — used for runtime queries. Allows Prisma prepared statements → faster than transaction pooler.
# TRANSACTION POOLER (port 6543, pgbouncer=true) — alternative, but disables prepared statements.
# DIRECT_URL (port 5432 on db host) — used ONLY by prisma migrate / prisma db push.
DATABASE_URL=postgresql://postgres.phgcujuexybguiducwcs:LPhwzkppwZhPmjjO@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require&connection_limit=5&pool_timeout=10&connect_timeout=10
DIRECT_URL=postgresql://postgres.phgcujuexybguiducwcs:LPhwzkppwZhPmjjO@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
# TRANSACTION_POOLER_URL=postgresql://postgres.phgcujuexybguiducwcs:LPhwzkppwZhPmjjO@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# JWT Configuration
JWT_SECRET=dev-jwt-secret-5d99876217d166b5337cffedabb63082
JWT_EXPIRES_IN=24h

# Swagger Basic Auth
SWAGGER_BASIC_AUTH_USER=axpo
SWAGGER_BASIC_AUTH_PASS="cdvRBH#3tenrwbvCE#WVB"

# CORS
CORS_ORIGIN=*

# Node Environment
NODE_ENV=development
APP_ENV=dev

# Server
PORT=3000
NEXT_PUBLIC_API_URL=https://axpo-dev.vercel.app/api/v1
NEXT_PUBLIC_PUBLIC_API_URL=https://axpo-dev.vercel.app/api/v1/public
NEXT_PUBLIC_FRONTEND_SIMULADOR_URL=https://tuenergia.axpoiberia.es
FRONTEND_SIMULADOR_URL=https://tuenergia.axpoiberia.es

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Token Configuration
PUBLIC_TOKEN_LENGTH=64
PIN_LENGTH=4
PIN_SALT_ROUNDS=10

# Feature Flags
FEATURE_OCR_ENABLED=false
FEATURE_PDF_EXPORT_ENABLED=false
FEATURE_ANALYTICS_ENABLED=true

DB_CONNECTION_MODE=api
